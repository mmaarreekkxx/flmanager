<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PDF LOCKER</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Exo+2:wght@300;400;600;700;900&display=swap" rel="stylesheet">
<style>
:root{--bg:#080b10;--surface:#0e1420;--card:#131926;--border:#1e2a3a;--border2:#2a3a50;--accent:#f59e0b;--accentDim:#92400e;--blue:#38bdf8;--green:#34d399;--red:#f87171;--text:#e2e8f0;--muted:#64748b;--mono:'Share Tech Mono',monospace;--sans:'Exo 2',sans-serif}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:var(--sans);min-height:100vh;min-height:100dvh;overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(245,158,11,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(245,158,11,.03) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0}
#loader{position:fixed;inset:0;z-index:100;background:var(--bg);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;transition:opacity .3s}
#loader.out{opacity:0;pointer-events:none}
.l-ring{width:44px;height:44px;border:3px solid var(--border2);border-top-color:var(--accent);border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.l-t{font-family:var(--mono);font-size:13px;color:var(--accent);letter-spacing:4px;text-transform:uppercase}
.l-bar{width:160px;height:2px;background:var(--border2);border-radius:2px;overflow:hidden}
.l-fill{height:100%;width:0%;background:linear-gradient(90deg,var(--accentDim),var(--accent));border-radius:2px;transition:width .75s ease}
#hackerOverlay{position:fixed;inset:0;z-index:90;background:rgba(0,0,0,.92);display:none;flex-direction:column;align-items:center;justify-content:center;overflow:hidden}
#hackerOverlay.active{display:flex}
.hk-rain{position:absolute;inset:0;overflow:hidden;pointer-events:none;z-index:0}
.hk-col{position:absolute;top:-100%;font-family:var(--mono);font-size:12px;color:rgba(52,211,153,.15);line-height:1.2;writing-mode:vertical-rl;animation:hkFall linear infinite;white-space:nowrap}
@keyframes hkFall{0%{transform:translateY(-100%)}100%{transform:translateY(calc(100vh + 100%))}}
.hk-center{position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;gap:12px;padding:30px;max-width:500px;width:90%}
.hk-lock{font-size:48px;animation:hkPulse 1s ease-in-out infinite}
@keyframes hkPulse{0%,100%{transform:scale(1);filter:drop-shadow(0 0 8px rgba(245,158,11,.4))}50%{transform:scale(1.1);filter:drop-shadow(0 0 20px rgba(245,158,11,.8))}}
.hk-title{font-family:var(--mono);font-size:14px;color:var(--accent);letter-spacing:4px;text-transform:uppercase;text-align:center}
.hk-file{font-family:var(--mono);font-size:10px;color:var(--green);text-align:center;max-width:100%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.hk-progress{width:100%;max-width:300px;height:4px;background:var(--border2);border-radius:2px;overflow:hidden}
.hk-progress-fill{height:100%;background:linear-gradient(90deg,var(--accentDim),var(--accent),var(--green));border-radius:2px;transition:width .3s;width:0%;box-shadow:0 0 10px rgba(245,158,11,.5)}
.hk-terminal{width:100%;max-width:400px;background:rgba(0,0,0,.6);border:1px solid var(--border2);border-radius:6px;padding:10px;font-family:var(--mono);font-size:8px;color:var(--green);max-height:120px;overflow-y:auto;line-height:1.6}
.hk-terminal::-webkit-scrollbar{width:2px}.hk-terminal::-webkit-scrollbar-thumb{background:var(--border2)}
.hk-line{opacity:0;animation:hkType .3s ease forwards}
@keyframes hkType{to{opacity:1}}
.hk-line .hk-prompt{color:var(--accent)}.hk-line .hk-cmd{color:var(--green)}.hk-line .hk-val{color:var(--blue)}.hk-line .hk-ok{color:var(--green)}.hk-line .hk-warn{color:var(--accent)}
.hk-hex{font-family:var(--mono);font-size:7px;color:rgba(52,211,153,.2);text-align:center;max-width:100%;overflow:hidden;word-break:break-all;line-height:1.4;max-height:30px}
.hk-stats{display:flex;gap:16px;font-family:var(--mono);font-size:9px}
.hk-stat{text-align:center}.hk-stat-val{font-size:16px;font-weight:700;color:var(--accent);font-family:var(--mono)}.hk-stat-lbl{font-size:7px;color:var(--muted);margin-top:2px;letter-spacing:1px}
.hk-status{font-family:var(--mono);font-size:10px;color:var(--accent);animation:hkBlink 1s step-end infinite}
@keyframes hkBlink{50%{opacity:0}}
#hackerOverlay.dm .hk-lock{animation-name:hkPulseB}
@keyframes hkPulseB{0%,100%{transform:scale(1);filter:drop-shadow(0 0 8px rgba(56,189,248,.4))}50%{transform:scale(1.1);filter:drop-shadow(0 0 20px rgba(56,189,248,.8))}}
#hackerOverlay.dm .hk-title{color:var(--blue)}
#hackerOverlay.dm .hk-progress-fill{background:linear-gradient(90deg,#0c4a6e,var(--blue),var(--green));box-shadow:0 0 10px rgba(56,189,248,.5)}
#hackerOverlay.dm .hk-stat-val{color:var(--blue)}
#hackerOverlay.dm .hk-status{color:var(--blue)}
#hackerOverlay.dm .hk-prompt{color:var(--blue)}

#app{position:relative;z-index:1;max-width:960px;margin:0 auto;padding:16px 12px 50px;opacity:0;transform:translateY(6px);transition:opacity .3s,transform .3s}
#app.vis{opacity:1;transform:none}
.hdr{display:flex;align-items:center;gap:10px;margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid var(--border)}
.hdr-ico{width:28px;height:28px;background:linear-gradient(135deg,var(--accentDim),var(--accent));border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:13px;box-shadow:0 0 8px rgba(245,158,11,.2);flex-shrink:0}
.hdr h1{font-size:13px;font-weight:900;letter-spacing:2px;text-transform:uppercase}
.hdr-s{font-size:8px;color:var(--muted);font-family:var(--mono);letter-spacing:1px}
.hdr-b{margin-left:auto;font-family:var(--mono);font-size:7px;color:var(--accent);border:1px solid var(--accentDim);padding:2px 5px;border-radius:3px;white-space:nowrap}
.eng{display:flex;align-items:center;gap:6px;padding:4px 10px;border-radius:5px;background:var(--surface);border:1px solid var(--border);font-size:8px;font-family:var(--mono);color:var(--muted);margin-bottom:10px;flex-wrap:wrap}
.ed{width:6px;height:6px;border-radius:50%;flex-shrink:0}.ed.ld{background:var(--accent);animation:pulse 1s infinite}.ed.ok{background:var(--green);animation:none}.ed.er{background:var(--red);animation:none}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.eb{flex:0 0 80px;height:2px;background:var(--border);border-radius:2px;overflow:hidden;margin-left:auto}.eb.h{display:none}
.ef{height:100%;background:var(--accent);border-radius:2px;transition:width .3s;width:0%}
.aban{display:none;align-items:center;gap:6px;padding:5px 9px;border-radius:6px;margin-bottom:8px;font-family:var(--mono);font-size:9px;animation:sUp .3s}
.aban.show{display:flex}
.aban.be{background:rgba(245,158,11,.07);border:1px solid rgba(245,158,11,.2);color:var(--accent)}
.aban.bd{background:rgba(56,189,248,.07);border:1px solid rgba(56,189,248,.2);color:var(--blue)}
.aban.bw{background:rgba(248,113,113,.07);border:1px solid rgba(248,113,113,.2);color:var(--red)}
@keyframes sUp{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}
.main-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.card{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:14px;position:relative;overflow:hidden}
.card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--accent),transparent);opacity:0;transition:opacity .3s}
.card:hover::before{opacity:1}
.ct{font-size:8px;font-family:var(--mono);letter-spacing:2px;color:var(--accent);text-transform:uppercase;margin-bottom:10px;display:flex;align-items:center;gap:5px}
.ct::before{content:'';width:2px;height:9px;background:var(--accent);border-radius:2px;flex-shrink:0}
.dz{border:2px dashed var(--border2);border-radius:9px;padding:20px 10px;text-align:center;cursor:pointer;transition:all .2s;position:relative}
.dz:hover,.dz.ov{border-color:var(--accent);background:rgba(245,158,11,.04)}
.dz input[type="file"]{position:absolute;inset:0;opacity:0;cursor:pointer}
.dz-i{font-size:24px;margin-bottom:4px;display:block}.dz-m{font-weight:600;font-size:11px;margin-bottom:2px}.dz-s{font-size:8px;color:var(--muted);font-family:var(--mono)}
.flist{margin-top:10px;display:flex;flex-direction:column;gap:5px;max-height:240px;overflow-y:auto;padding-right:2px}
.fitem{display:flex;align-items:center;gap:7px;background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:7px 9px;animation:sUp .2s}
.fitem.skipped{opacity:.4}
.fitem-ico{font-size:15px;flex-shrink:0}.fitem-info{flex:1;min-width:0}
.fitem-name{font-size:9px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.fitem-meta{font-size:7px;color:var(--muted);font-family:var(--mono);margin-top:1px;display:flex;gap:5px;align-items:center;flex-wrap:wrap}
.fitem-badge{font-size:7px;padding:1px 4px;border-radius:3px;font-family:var(--mono);font-weight:600}
.fitem-badge.enc{background:rgba(245,158,11,.12);color:var(--accent)}
.fitem-badge.opn{background:rgba(100,116,139,.1);color:var(--muted)}
.fitem-badge.skip{background:rgba(248,113,113,.1);color:var(--red)}
.fitem-status{font-size:7px;font-family:var(--mono);padding:1px 5px;border-radius:3px;flex-shrink:0;white-space:nowrap}
.fitem-status.wait{color:var(--muted);background:rgba(100,116,139,.08)}
.fitem-status.proc{color:var(--accent);background:rgba(245,158,11,.08)}
.fitem-status.done{color:var(--green);background:rgba(52,211,153,.08)}
.fitem-status.fail{color:var(--red);background:rgba(248,113,113,.08)}
.fitem-status.skip{color:var(--muted);background:rgba(100,116,139,.08)}
.fitem-rm{background:none;border:none;cursor:pointer;color:var(--muted);font-size:10px;padding:2px;flex-shrink:0;line-height:1}.fitem-rm:hover{color:var(--red)}
.fcnt{font-size:7px;font-family:var(--mono);color:var(--muted);margin-top:6px;display:none;align-items:center;gap:5px;flex-wrap:wrap}
.fcnt.show{display:flex}.fcnt .n{color:var(--accent);font-weight:700}
.clear-all{font-size:7px;font-family:var(--mono);color:var(--red);background:none;border:none;cursor:pointer;margin-left:auto;padding:2px 5px;border-radius:3px}.clear-all:hover{background:rgba(248,113,113,.1)}
.fg{margin-bottom:10px}
label.fl{display:block;font-size:8px;font-family:var(--mono);letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-bottom:4px}
.iw{position:relative}
input[type="text"],input[type="password"],select{width:100%;background:var(--surface);border:1px solid var(--border2);border-radius:6px;padding:8px 10px;font-size:11px;font-family:var(--mono);color:var(--text);outline:none;transition:border-color .2s,box-shadow .2s;appearance:none}
input:focus,select:focus{border-color:var(--accent);box-shadow:0 0 0 2px rgba(245,158,11,.1)}
input[type="password"]{padding-right:30px;letter-spacing:2px}
.eye{position:absolute;right:6px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--muted);font-size:11px;padding:2px}.eye:hover{color:var(--accent)}
.str-b{height:2px;background:var(--border);border-radius:2px;margin-top:4px;overflow:hidden}
.str-f{height:100%;border-radius:2px;transition:width .3s,background .3s;width:0%}
.str-l{font-size:7px;font-family:var(--mono);margin-top:2px;color:var(--muted)}
select option{background:#131926}
.opt-row{display:flex;align-items:center;gap:7px;padding:7px 9px;background:var(--surface);border:1px solid var(--border);border-radius:6px;margin-bottom:8px;cursor:pointer;user-select:none;transition:all .2s}
.opt-row:hover{border-color:var(--accent)}
.opt-row input[type="checkbox"]{width:13px;height:13px;accent-color:var(--accent);cursor:pointer;flex-shrink:0}
.opt-ico{font-size:14px;flex-shrink:0}.opt-txt{flex:1}
.opt-title{font-size:9px;font-weight:600;color:var(--text)}
.opt-desc{font-size:7px;color:var(--muted);font-family:var(--mono);line-height:1.3;margin-top:1px}
.opt-body{display:none;margin-bottom:10px;padding:0 0 0 4px}.opt-body.show{display:block}
.or-label{font-size:7px;font-family:var(--mono);color:var(--border2);text-align:center;margin:-4px 0 4px;letter-spacing:3px}
.btn{width:100%;border:none;border-radius:8px;padding:10px 14px;color:#000;font-family:var(--sans);font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all .2s;margin-top:4px;display:flex;align-items:center;justify-content:center;gap:6px}
.btn:hover:not(:disabled){transform:translateY(-1px)}
.btn:disabled{background:var(--border2)!important;color:var(--muted);cursor:not-allowed;transform:none!important;box-shadow:none!important}
.bte{background:linear-gradient(135deg,#92400e,var(--accent))}.bte:hover:not(:disabled){box-shadow:0 3px 14px rgba(245,158,11,.3)}
.btd{background:linear-gradient(135deg,#0c4a6e,var(--blue))}.btd:hover:not(:disabled){box-shadow:0 3px 14px rgba(56,189,248,.3)}
.batch-prog{margin-top:8px;display:none}.batch-prog.show{display:block}
.bp-bar{height:3px;background:var(--border);border-radius:2px;overflow:hidden}
.bp-fill{height:100%;background:var(--green);border-radius:2px;transition:width .2s;width:0%}
.bp-lbl{font-size:7px;font-family:var(--mono);color:var(--muted);margin-top:2px;text-align:center}
.rc{margin-top:12px;display:none;animation:sUp .3s}.rc.show{display:block}
.ri{border-radius:9px;padding:12px 14px;display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.rie{background:rgba(52,211,153,.06);border:1px solid rgba(52,211,153,.3)}
.rid{background:rgba(56,189,248,.06);border:1px solid rgba(56,189,248,.3)}
.ri-i{font-size:22px}.ri-t h3{font-size:11px;font-weight:700;margin-bottom:2px}
.rie .ri-t h3{color:var(--green)}.rid .ri-t h3{color:var(--blue)}
.ri-t p{font-size:8px;color:var(--muted);font-family:var(--mono);word-break:break-all}
.bdl{margin-left:auto;border:none;border-radius:6px;padding:7px 12px;color:#000;font-family:var(--sans);font-size:9px;font-weight:700;letter-spacing:1px;text-transform:uppercase;cursor:pointer;transition:all .2s;text-decoration:none;display:inline-flex;align-items:center;gap:3px;flex-shrink:0}
.dle{background:var(--green)}.dle:hover{background:#6ee7b7}
.dld{background:var(--blue)}.dld:hover{background:#7dd3fc}
.lc{margin-top:10px}
.lb{background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:7px;font-family:var(--mono);font-size:8px;min-height:28px;max-height:90px;overflow-y:auto;line-height:1.6}
.ll{display:flex;gap:5px}.lt{color:var(--border2);flex-shrink:0}
.lok{color:var(--green)}.ler{color:var(--red)}.lin{color:var(--muted)}.lwa{color:var(--accent)}
.hint{font-size:8px;color:var(--muted);font-family:var(--mono);line-height:1.4;padding:6px 8px;background:var(--surface);border:1px solid var(--border);border-radius:5px;margin-top:6px}
@media(max-width:700px){
  #app{padding:10px 8px 40px}.main-grid{grid-template-columns:1fr}
  .hdr h1{font-size:12px}.hdr-s{display:none}
  .dz{padding:16px 8px}.dz-i{font-size:20px}.dz-m{font-size:10px}
  .flist{max-height:180px}.card{padding:12px}
  .btn{padding:9px 10px;font-size:10px}
  .ri{padding:10px;gap:8px;flex-direction:column;align-items:stretch}
  .bdl{margin-left:0;width:100%;justify-content:center}
  .lb{max-height:70px;font-size:7px}
  .hk-terminal{font-size:7px;max-height:90px}
  .hk-stats{gap:10px}.hk-stat-val{font-size:13px}
}
@media(min-width:1100px){
  #app{max-width:1060px;padding:24px 30px 60px}
  .main-grid{gap:18px}.card{padding:20px}
  .dz{padding:28px 14px}.flist{max-height:300px}
}
::-webkit-scrollbar{width:3px}::-webkit-scrollbar-track{background:var(--surface)}::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
</style>
</head>
<body>
<div id="loader"><div class="l-ring"></div><div class="l-t">PDF LOCKER</div><div class="l-bar"><div class="l-fill" id="lFill"></div></div></div>

<div id="hackerOverlay">
  <div class="hk-rain" id="hkRain"></div>
  <div class="hk-center">
    <div class="hk-lock" id="hkLock">🔒</div>
    <div class="hk-title" id="hkTitle">SZYFROWANIE</div>
    <div class="hk-file" id="hkFile">—</div>
    <div class="hk-stats">
      <div class="hk-stat"><div class="hk-stat-val" id="hkDone">0</div><div class="hk-stat-lbl">GOTOWE</div></div>
      <div class="hk-stat"><div class="hk-stat-val" id="hkTotal">0</div><div class="hk-stat-lbl">RAZEM</div></div>
      <div class="hk-stat"><div class="hk-stat-val" id="hkPct">0%</div><div class="hk-stat-lbl">POSTĘP</div></div>
    </div>
    <div class="hk-progress"><div class="hk-progress-fill" id="hkBar"></div></div>
    <div class="hk-status" id="hkStatus">INICJALIZACJA...</div>
    <div class="hk-terminal" id="hkTerm"></div>
    <div class="hk-hex" id="hkHex"></div>
  </div>
</div>

<div id="app">
  <div class="hdr"><div class="hdr-ico">🔒</div><div><h1>PDF Locker</h1><div class="hdr-s">SZYFRUJ / ODSZYFRUJ PDF</div></div><div class="hdr-b">v15 · LOCAL</div></div>
  <div class="eng"><div class="ed ld" id="eDot"></div><span id="eLbl">Silnik startuje…</span><div class="eb" id="eBar"><div class="ef" id="eFill"></div></div></div>
  <div class="aban" id="aBan"><span id="aBIco"></span><span id="aBTxt"></span></div>
  <div class="main-grid">
    <div class="card">
      <div class="ct">01 — Pliki PDF</div>
      <div class="dz" id="dz"><input type="file" id="fi" accept=".pdf" multiple><span class="dz-i">📄</span><div class="dz-m">Przeciągnij pliki PDF</div><div class="dz-s">lub kliknij · można wybrać wiele</div></div>
      <div class="flist" id="flist"></div>
      <div class="fcnt" id="fcnt"><span>Plików: <span class="n" id="fcntN">0</span></span><span>·</span><span id="fcntE">0 zaszyfr.</span><span>·</span><span id="fcntO">0 otwartych</span><button class="clear-all" id="clearAll">✕ Usuń wszystkie</button></div>
    </div>
    <div class="card">
      <div class="ct" id="stTitle">02 — Hasła</div>
      <div class="fg"><label class="fl">🔑 Hasło użytkownika *</label><div class="iw"><input type="password" id="uP" placeholder="Wymagane" autocomplete="new-password"><button class="eye" id="eyU">👁</button></div><div class="str-b"><div class="str-f" id="sFill"></div></div><div class="str-l" id="sLbl">Siła: —</div></div>
      <div class="fg" id="cfgr"><label class="fl">Potwierdź hasło *</label><div class="iw"><input type="password" id="cP" placeholder="Powtórz…" autocomplete="new-password"><button class="eye" id="eyC">👁</button></div><div class="str-l" id="mLbl" style="margin-top:3px">—</div></div>

      <label class="opt-row" id="ownerRow"><input type="checkbox" id="ownerChk"><span class="opt-ico">👤</span><div class="opt-txt"><div class="opt-title">Hasło właściciela</div><div class="opt-desc">Opcjonalne — osobne hasło z pełnymi prawami</div></div></label>
      <div class="opt-body" id="ownerBody"><div class="fg"><div class="iw"><input type="password" id="oP" placeholder="Hasło właściciela…" autocomplete="new-password"><button class="eye" id="eyO">👁</button></div></div></div>

      <div class="or-label" id="orLabel">— LUB —</div>

      <label class="opt-row" id="adminRow"><input type="checkbox" id="adminChk" checked><span class="opt-ico">🛡️</span><div class="opt-txt"><div class="opt-title">Hasło administratora</div><div class="opt-desc">Stałe hasło master — odblokuje każdy plik</div></div></label>

      <div class="fg" id="algoRow"><label class="fl">Algorytm</label><select id="algo"><option value="AES-256-R5">AES-256</option><option value="AES-128">AES-128</option><option value="RC4-128">RC4-128</option><option value="RC4-40">RC4-40</option></select></div>

      <button class="btn bte" id="btnA" disabled>🔒 Zaszyfruj</button>
      <div class="batch-prog" id="bProg"><div class="bp-bar"><div class="bp-fill" id="bpF"></div></div><div class="bp-lbl" id="bpL">0 / 0</div></div>
      <div class="hint" id="hBox">ℹ️ Dodaj pliki PDF.</div>
    </div>
  </div>
  <div class="rc" id="rC"><div class="ri" id="rI"><span class="ri-i" id="rIco">✅</span><div class="ri-t"><h3 id="rTit">Gotowe!</h3><p id="rMet">—</p></div><button class="bdl dle" id="dlAll">⬇ Pobierz wszystkie</button></div></div>
  <div class="card lc"><div class="ct">Log</div><div class="lb" id="logB"><div class="ll"><span class="lt">--:--:--</span><span class="lin">Start…</span></div></div></div>
</div>

<script>
'use strict';
let pyodide=null,ready=false,busy=false,files=[],blobs=[],uid=0;
const $=id=>document.getElementById(id);
const _ak=[70,108,111,116,97,50,48,50,54];
function _ap(){return String.fromCharCode(..._ak)}

requestAnimationFrame(()=>$('lFill').style.width='100%');
setTimeout(()=>{$('loader').classList.add('out');$('app').classList.add('vis')},1000);

function log(m,t='in'){const n=new Date().toTimeString().slice(0,8),el=$('logB'),r=document.createElement('div');r.className='ll';r.innerHTML=`<span class="lt">${n}</span><span class="l${t}">${String(m).replace(/&/g,'&amp;').replace(/</g,'&lt;')}</span>`;el.appendChild(r);el.scrollTop=el.scrollHeight}
function fB(b,d=1){if(b<1024)return b+' B';if(b<1048576)return(b/1024).toFixed(d)+' KB';return(b/1048576).toFixed(d)+' MB'}
['eyU:uP','eyC:cP','eyO:oP'].forEach(p=>{const[b,i]=p.split(':');$(b).onclick=()=>{const e=$(i);if(e.type==='password'){e.type='text';$(b).textContent='🙈'}else{e.type='password';$(b).textContent='👁'}}});

/*
  CHECKBOX LOGIC:
  - Zaznaczenie jednego → odznacza drugi (jak radio)
  - Ale MOŻNA odznaczyć oba (w przeciwieństwie do radio)
  - ownerChk ON → adminChk OFF, pokaż pole hasła
  - adminChk ON → ownerChk OFF, ukryj pole hasła
  - oba OFF → owner_password = hasło użytkownika
*/
$('ownerChk').onchange=function(){
  if(this.checked) $('adminChk').checked=false;
  syncOpts();
};
$('adminChk').onchange=function(){
  if(this.checked){
    $('ownerChk').checked=false;
    $('oP').value='';
  }
  syncOpts();
};
function syncOpts(){
  $('ownerBody').classList.toggle('show',$('ownerChk').checked);
  updUI();
}
$('oP').oninput=updBtn;

function calcS(p){let s=0;if(p.length>=8)s++;if(p.length>=12)s++;if(/[A-Z]/.test(p))s++;if(/[0-9]/.test(p))s++;if(/[^a-zA-Z0-9]/.test(p))s++;return s}
const SC=['#ef4444','#f97316','#f59e0b','#84cc16','#22c55e'],SN=['Bardzo słabe','Słabe','Średnie','Silne','Bardzo silne'];
$('uP').oninput=function(){const p=this.value,s=calcS(p),f=$('sFill'),l=$('sLbl');if(!p){f.style.width='0%';f.style.background='transparent';l.textContent='Siła: —';l.style.color='#64748b'}else{const i=Math.max(0,s-1);f.style.width=(s/5*100)+'%';f.style.background=SC[i];l.textContent='Siła: '+SN[i];l.style.color=SC[i]}chkM();updBtn()};
$('cP').oninput=()=>{chkM();updBtn()};
function chkM(){const a=$('uP').value,b=$('cP').value,l=$('mLbl');if(!b){l.textContent='—';l.style.color='#64748b'}else if(a===b){l.textContent='✓ Zgodne';l.style.color='#34d399'}else{l.textContent='✗ Niezgodne';l.style.color='#f87171'}}

function getMode(){return files.some(f=>f.enc)?'dec':'enc'}
function getActiveFiles(){return getMode()==='dec'?files.filter(f=>f.enc):files.filter(f=>!f.enc)}
function getSkippedFiles(){return getMode()==='dec'?files.filter(f=>!f.enc):[]}

function updUI(){
  const m=getMode(),n=files.length,ec=files.filter(f=>f.enc).length,oc=n-ec,active=getActiveFiles(),skipped=getSkippedFiles();
  if(n){$('fcnt').classList.add('show');$('fcntN').textContent=n;$('fcntE').textContent=ec+' zaszyfr.';$('fcntO').textContent=oc+' otwartych'}else $('fcnt').classList.remove('show');
  const btn=$('btnA'),isEnc=m==='enc';
  if(isEnc){btn.className='btn bte';btn.innerHTML='🔒 Zaszyfruj'+(active.length>1?' ('+active.length+')':'');$('cfgr').style.display='';$('stTitle').textContent='02 — Hasła szyfrowania'}
  else{btn.className='btn btd';btn.innerHTML='🔓 Odszyfruj'+(active.length>1?' ('+active.length+')':'');$('cfgr').style.display='none';$('stTitle').textContent='02 — Hasło odszyfrowania'}
  $('ownerRow').style.display=isEnc?'':'none';
  $('ownerBody').classList.toggle('show',isEnc&&$('ownerChk').checked);
  $('orLabel').style.display=isEnc?'':'none';
  $('adminRow').style.display=isEnc?'':'none';
  $('algoRow').style.display=isEnc?'':'none';

  if(skipped.length)$('hBox').textContent='⚠️ '+skipped.length+' otwartych pominięto — priorytet: odszyfrowanie.';
  else if(isEnc){
    const p=['🔑 Użytk.'];
    if($('ownerChk').checked)p.push('👤 Właśc.');
    if($('adminChk').checked)p.push('🛡️ Admin');
    $('hBox').textContent='ℹ️ Hasła: '+p.join(' + ')
  }else $('hBox').textContent='ℹ️ Wpisz hasło aby odblokować.';

  if(skipped.length&&active.length){const b=$('aBan');b.classList.remove('show','be','bd','bw');b.classList.add('show','bw');$('aBIco').textContent='⚠️';$('aBTxt').textContent=active.length+' zaszyfr. do odblokowania, '+skipped.length+' otwartych pominięto'}
  updBtn()
}

function updBtn(){
  const m=getMode(),pw=$('uP').value,cp=$('cP').value,a=getActiveFiles();
  let ok=ready&&a.length&&pw&&!busy;
  if(m==='enc')ok=ok&&pw===cp;
  if($('ownerChk').checked&&m==='enc')ok=ok&&$('oP').value.length>0;
  $('btnA').disabled=!ok
}

function detectEnc(bytes){return new TextDecoder('latin1').decode(bytes.slice(Math.max(0,bytes.length-16384))).includes('/Encrypt')}
async function detectEncPy(bytes){if(!ready)return null;try{pyodide.FS.writeFile('/tmp/_d.pdf',bytes);const r=await pyodide.runPythonAsync(`from pypdf import PdfReader;"1" if PdfReader("/tmp/_d.pdf").is_encrypted else "0"`);try{pyodide.FS.unlink('/tmp/_d.pdf')}catch(_){}return r==="1"}catch(_){return null}}

const dz=$('dz'),fi=$('fi');
dz.ondragover=e=>{e.preventDefault();dz.classList.add('ov')};dz.ondragleave=e=>{e.preventDefault();dz.classList.remove('ov')};
dz.ondrop=e=>{e.preventDefault();dz.classList.remove('ov');handleNew(e.dataTransfer.files)};
fi.onchange=()=>{handleNew(fi.files)};$('clearAll').onclick=clearAll;

async function handleNew(fl){
  const arr=Array.from(fl);fi.value='';
  const reads=arr.map(async f=>{if(!f.name.toLowerCase().endsWith('.pdf')){log(f.name+' — nie PDF','er');return null}if(!f.size){log(f.name+' — pusty','er');return null}if(files.some(x=>x.file.name===f.name&&x.file.size===f.size)){log(f.name+' — duplikat','wa');return null}return{f,bytes:new Uint8Array(await f.arrayBuffer())}});
  const res=await Promise.all(reads);
  for(const r of res){if(!r)continue;const enc=detectEnc(r.bytes);files.push({id:++uid,file:r.f,bytes:r.bytes,enc,status:'wait',result:null});log((enc?'🔐':'📄')+' '+r.f.name+' ('+fB(r.f.size)+')','ok')}
  renderFiles();updUI();
  if(ready){let c=false;for(const f of files){if(f.status!=='wait')continue;const p=await detectEncPy(f.bytes);if(p!==null&&p!==f.enc){f.enc=p;c=true}}if(c){renderFiles();updUI()}}
}
function renderFiles(){
  const list=$('flist');list.innerHTML='';const skipIds=new Set(getSkippedFiles().map(f=>f.id));
  files.forEach(f=>{const el=document.createElement('div');el.className='fitem'+(skipIds.has(f.id)?' skipped':'');el.id='fi_'+f.id;
  let badge,st;if(skipIds.has(f.id)){badge='<span class="fitem-badge skip">⏭️ POMINIĘTY</span>';st='Pominięty';f.status='skip'}else{badge=f.enc?'<span class="fitem-badge enc">🔐 ZASZYFR.</span>':'<span class="fitem-badge opn">🔓 OTWARTY</span>';st={wait:'Oczekuje',proc:'Przetwarzanie…',done:'✓ Gotowe',fail:'✗ Błąd',skip:'Pominięty'}[f.status]||'Oczekuje'}
  el.innerHTML=`<span class="fitem-ico">${skipIds.has(f.id)?'⏭️':f.enc?'🔐':'📄'}</span><div class="fitem-info"><div class="fitem-name">${f.file.name}</div><div class="fitem-meta">${fB(f.file.size)} ${badge}</div></div><span class="fitem-status ${f.status}">${st}</span><button class="fitem-rm" data-id="${f.id}">✕</button>`;list.appendChild(el)});
  list.querySelectorAll('.fitem-rm').forEach(b=>{b.onclick=()=>{files=files.filter(f=>f.id!==+b.dataset.id);renderFiles();updUI();if(!getSkippedFiles().length)$('aBan').classList.remove('show')}})
}
function clearAll(){files=[];blobs.forEach(u=>URL.revokeObjectURL(u));blobs=[];renderFiles();$('rC').classList.remove('show');$('aBan').classList.remove('show');updUI();log('Usunięto.','in')}
function setSt(id,s){const f=files.find(x=>x.id===id);if(f)f.status=s;const el=document.querySelector(`#fi_${id} .fitem-status`);if(el){el.className='fitem-status '+s;el.textContent={wait:'Oczekuje',proc:'Przetwarzanie…',done:'✓ Gotowe',fail:'✗ Błąd',skip:'Pominięty'}[s]}}

/* ═══ HACKER ═══ */
const hkC='ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789@#$%^&*(){}[]|;:<>,.?/~`';
let hexIv=null;
function rHex(n){let s='';for(let i=0;i<n;i++)s+='0123456789ABCDEF'[Math.random()*16|0];return s}
function hkShow(mode,total){
  const ov=$('hackerOverlay');ov.classList.add('active');ov.classList.toggle('dm',mode==='dec');
  $('hkLock').textContent=mode==='dec'?'🔓':'🔒';$('hkTitle').textContent=mode==='dec'?'ODSZYFROWANIE':'SZYFROWANIE';
  $('hkFile').textContent='Inicjalizacja…';$('hkDone').textContent='0';$('hkTotal').textContent=total;$('hkPct').textContent='0%';$('hkBar').style.width='0%';
  $('hkStatus').textContent='INICJALIZACJA...';$('hkStatus').style.animation='';$('hkTerm').innerHTML='';$('hkHex').textContent='';
  const rain=$('hkRain');rain.innerHTML='';
  for(let i=0;i<20;i++){const col=document.createElement('div');col.className='hk-col';col.style.left=(i*5+Math.random()*3)+'%';col.style.animationDuration=(4+Math.random()*8)+'s';col.style.animationDelay=(-Math.random()*5)+'s';col.style.fontSize=(8+Math.random()*6)+'px';let t='';for(let j=0;j<40;j++)t+=hkC[Math.random()*hkC.length|0]+'\n';col.textContent=t;rain.appendChild(col)}
  hexIv=setInterval(()=>{$('hkHex').textContent=rHex(60)},80)
}
function hkUpd(fn,done,total,st){$('hkFile').textContent=fn;$('hkDone').textContent=done;const p=Math.round(done/total*100);$('hkPct').textContent=p+'%';$('hkBar').style.width=p+'%';$('hkStatus').textContent=st}
function hkLog(text,type='cmd'){const term=$('hkTerm'),line=document.createElement('div');line.className='hk-line';const ts=new Date().toTimeString().slice(0,8);
  if(type==='cmd')line.innerHTML=`<span class="hk-prompt">[${ts}]</span> <span class="hk-cmd">${text}</span>`;
  else if(type==='ok')line.innerHTML=`<span class="hk-prompt">[${ts}]</span> <span class="hk-ok">✓ ${text}</span>`;
  else if(type==='val')line.innerHTML=`<span class="hk-prompt">[${ts}]</span> <span class="hk-val">${text}</span>`;
  else if(type==='warn')line.innerHTML=`<span class="hk-prompt">[${ts}]</span> <span class="hk-warn">⚠ ${text}</span>`;
  else line.innerHTML=`<span class="hk-prompt">[${ts}]</span> <span class="hk-cmd">${text}</span>`;
  term.appendChild(line);term.scrollTop=term.scrollHeight}
function hkHide(){clearInterval(hexIv);$('hackerOverlay').classList.remove('active','dm');$('hkRain').innerHTML=''}
async function hkDelay(ms){return new Promise(r=>setTimeout(r,ms))}

/* ═══ PROCESS ═══ */
$('btnA').onclick=processAll;
async function processAll(){
  const active=getActiveFiles();if(!active.length||!ready||busy)return;
  busy=true;const m=getMode();
  const userPw=$('uP').value,hasOwner=$('ownerChk').checked,ownerPw=hasOwner?$('oP').value:'';
  const hasAdmin=$('adminChk').checked,adminPw=hasAdmin?_ap():'',al=$('algo').value;
  const btn=$('btnA');btn.disabled=true;btn.innerHTML='⏳ Przetwarzanie…';
  $('rC').classList.remove('show');blobs.forEach(u=>URL.revokeObjectURL(u));blobs=[];
  active.forEach(f=>{f.status='wait';f.result=null});renderFiles();
  $('bProg').classList.add('show');

  hkShow(m,active.length);
  await hkDelay(300);hkLog('Inicjalizacja silnika kryptograficznego…');await hkDelay(200);
  hkLog('Algorytm: '+al,'val');await hkDelay(150);
  hkLog('Tryb: '+(m==='enc'?'ENCRYPT AES':'DECRYPT'),'val');await hkDelay(200);
  hkLog('Plików: '+active.length,'val');await hkDelay(300);

  let done=0,okCnt=0;const total=active.length;
  for(const f of active){
    setSt(f.id,'proc');$('bpF').style.width=(done/total*100)+'%';$('bpL').textContent=(done+1)+' / '+total;
    hkUpd(f.file.name,done,total,m==='enc'?'SZYFROWANIE...':'ŁAMANIE SZYFRU...');
    hkLog('Wczytywanie: '+f.file.name);await hkDelay(150);
    hkLog('Rozmiar: '+fB(f.file.size)+' | Bloki: '+Math.ceil(f.file.size/16),'val');await hkDelay(100);
    hkLog(m==='enc'?'Generowanie klucza...':'Próba odszyfrowania...');
    hkLog('Salt: 0x'+rHex(16),'val');await hkDelay(100);
    hkLog('IV: 0x'+rHex(32),'val');

    try{
      pyodide.FS.writeFile('/tmp/_p.pdf',f.bytes);
      if(m==='dec'){
        const pws=JSON.stringify([userPw,ownerPw,adminPw].filter(Boolean));
        pyodide.globals.set('_dec_pws',pws);
        hkLog('Testowanie haseł…');
        await pyodide.runPythonAsync(`
import json,io
from pypdf import PdfReader,PdfWriter
pws=json.loads(str(_dec_pws));data=open("/tmp/_p.pdf","rb").read()
for layer in range(3):
 r=PdfReader(io.BytesIO(data))
 if not r.is_encrypted:break
 ok=False
 for pw in pws:
  try:
   if r.decrypt(pw)>0:ok=True;break
  except:pass
 if not ok:raise RuntimeError("Nieprawidłowe hasło!")
 w=PdfWriter();w.clone_document_from_reader(r);buf=io.BytesIO();w.write(buf);data=buf.getvalue()
r2=PdfReader(io.BytesIO(data))
if r2.is_encrypted:raise RuntimeError("Nie odszyfrowano!")
with open("/tmp/_o.pdf","wb") as f:f.write(data)`);
        hkLog('Szyfr złamany!','ok');
      }else{
        const cfg=JSON.stringify({user:userPw,owner:ownerPw,admin:adminPw,hasOwner,hasAdmin,algo:al});
        pyodide.globals.set('_enc_cfg',cfg);hkLog('Szyfrowanie bloków…');
        await pyodide.runPythonAsync(`
import json
from pypdf import PdfReader,PdfWriter
cfg=json.loads(str(_enc_cfg));up=cfg['user'];op=cfg.get('owner','');ap=cfg.get('admin','')
ho=cfg.get('hasOwner',False);ha=cfg.get('hasAdmin',False);al=cfg.get('algo','AES-256-R5')
r=PdfReader("/tmp/_p.pdf")
if r.is_encrypted:raise RuntimeError("Już zaszyfrowany!")
fo=op if ho and op else(ap if ha and ap else up)
w=PdfWriter();w.clone_document_from_reader(r)
w.encrypt(user_password=up,owner_password=fo,algorithm=al,permissions_flag=-1)
with open("/tmp/_o.pdf","wb") as f:w.write(f)`);
        hkLog('Klucz '+al+' zastosowany','ok');
      }
      const out=pyodide.FS.readFile('/tmp/_o.pdf');const sfx=m==='dec'?'_unlocked':'_locked';
      const name=f.file.name.replace(/\.pdf$/i,sfx+'.pdf');
      const bl=new Blob([out],{type:'application/pdf'});const url=URL.createObjectURL(bl);
      blobs.push(url);f.result={name,url,size:out.length};setSt(f.id,'done');okCnt++;
      hkLog('Zapisano: '+name+' ('+fB(out.length)+')','ok');log('✅ '+name+' ('+fB(out.length)+')','ok');
    }catch(e){setSt(f.id,'fail');const msg=String(e.message||e);
      hkLog('BŁĄD: '+(msg.includes('hasło')||msg.includes('password')?'Nieprawidłowe hasło':msg),'warn');
      log('❌ '+f.file.name+': '+(msg.includes('hasło')||msg.includes('password')?'Złe hasło':msg),'er')}
    try{pyodide.FS.unlink('/tmp/_p.pdf')}catch(_){}
    try{pyodide.FS.unlink('/tmp/_o.pdf')}catch(_){}
    done++;$('bpF').style.width=(done/total*100)+'%';$('bpL').textContent=done+' / '+total;
    hkUpd(f.file.name,done,total,done===total?'ZAKOŃCZONO':'PRZETWARZANIE...');await hkDelay(200)
  }
  hkLog('═══════════════════════════');hkLog('Operacja: '+okCnt+'/'+total+' sukces','ok');
  hkUpd('ZAKOŃCZONO',done,total,'GOTOWE ✓');$('hkStatus').textContent='ZAKOŃCZONO ✓';$('hkStatus').style.animation='none';
  await hkDelay(1500);hkHide();

  if(okCnt){$('rI').className='ri '+(m==='enc'?'rie':'rid');$('dlAll').className='bdl '+(m==='enc'?'dle':'dld');
    $('rIco').textContent=okCnt===total?'✅':'⚠️';
    $('rTit').textContent=okCnt+'/'+total+' przetworzono'+(getSkippedFiles().length?' ('+getSkippedFiles().length+' pominięto)':'');
    $('rMet').textContent=active.filter(f=>f.result).map(f=>f.result.name).join(', ');$('rC').classList.add('show')}
  setTimeout(()=>$('bProg').classList.remove('show'),500);busy=false;updUI();updBtn()
}

$('dlAll').onclick=()=>{files.filter(f=>f.result).forEach((f,i)=>{setTimeout(()=>{const a=document.createElement('a');a.href=f.result.url;a.download=f.result.name;document.body.appendChild(a);a.click();document.body.removeChild(a)},i*400)})};

function eP(p,t){$('eFill').style.width=p+'%';$('eLbl').textContent=t}
(async()=>{const dot=$('eDot');try{
  eP(5,'Pobieranie Pyodide…');log('Pobieranie Pyodide…','in');
  if(typeof loadPyodide==='undefined'){await new Promise((ok,fail)=>{const s=document.createElement('script');s.src='https://cdn.jsdelivr.net/pyodide/v0.25.0/full/pyodide.js';s.onload=ok;s.onerror=()=>fail(new Error('Nie pobrano'));document.head.appendChild(s)})}
  eP(15,'Inicjalizacja…');pyodide=await loadPyodide({indexURL:'https://cdn.jsdelivr.net/pyodide/v0.25.0/full/'});log('Pyodide OK','ok');
  eP(35,'micropip…');await pyodide.loadPackage('micropip');const mp=pyodide.pyimport('micropip');
  eP(50,'cryptography…');log('cryptography…','in');await mp.install('cryptography');log('cryptography ✓','ok');
  eP(75,'pypdf…');log('pypdf…','in');await mp.install('pypdf');log('pypdf ✓','ok');
  eP(92,'Weryfikacja…');await pyodide.runPythonAsync('from pypdf import PdfReader,PdfWriter');
  try{pyodide.FS.mkdir('/tmp')}catch(_){}
  const pv=pyodide.runPython('import sys;sys.version.split()[0]');let ppv='?';try{ppv=pyodide.runPython('import pypdf;pypdf.__version__')}catch(_){}
  ready=true;dot.className='ed ok';eP(100,'Gotowy · Python '+pv+' · pypdf '+ppv+' · AES ✓');$('eBar').classList.add('h');log('Silnik ✓ (pypdf '+ppv+')','ok');updBtn();
  if(files.length){let c=false;for(const f of files){const p=await detectEncPy(f.bytes);if(p!==null&&p!==f.enc){f.enc=p;c=true}}if(c){renderFiles();updUI()}}
}catch(e){const m=e.message||String(e);dot.className='ed er';$('eLbl').textContent='Błąd: '+m;$('eBar').classList.add('h');log('INIT: '+m,'er')}})();
</script>
</body>
</html>
